# ShuttleWorks frontend — environment template.
#
# Vite exposes only variables prefixed ``VITE_`` to the client bundle.
# Copy to `.env.local` (or `.env`) and fill in the values for a real
# Supabase project. The `.env.local` file is gitignored.
#
# When ``VITE_SUPABASE_URL`` and ``VITE_SUPABASE_ANON_KEY`` are blank,
# the app runs in local-dev mode: the Supabase client is null, the
# AuthProvider exposes a synthetic session, and the AuthGuard lets
# every route through. Mirrors the backend's same-named env vars.

# API base. Vite proxies /api/* in dev; production builds use the
# absolute URL so the static frontend can talk to a different origin.
VITE_API_BASE_URL=/api

# Supabase project URL (e.g. https://xyzcompany.supabase.co)
VITE_SUPABASE_URL=

# Supabase anon (publishable) key — safe to ship in the client bundle.
VITE_SUPABASE_ANON_KEY=
