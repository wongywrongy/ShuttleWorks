# Tournament Scheduler Environment Configuration
# Copy this to .env and customize as needed

# === Compose project layout ===
# Project name namespaces containers, networks, and volumes so the
# tournament prototype (`tournament`) can run alongside this stack on
# the same Docker daemon. Host ports likewise differ across the two
# stacks; keep these defaults unless you intend to remap.
COMPOSE_PROJECT_NAME=btp
FRONTEND_HOST_PORT=80
BACKEND_HOST_PORT=8000

# === Backend ===
LOG_LEVEL=info

# === Frontend (build-time) ===
# API URL for frontend to call backend
# For Docker: /api (nginx proxies to backend)
# For development: http://localhost:8000
VITE_API_BASE_URL=/api

# === Future Cloud Deployment ===
# Uncomment and configure when deploying to cloud
#
# DATABASE_URL=postgresql://user:pass@host:5432/db
# REDIS_URL=redis://host:6379
# SECRET_KEY=your-secret-key-here
