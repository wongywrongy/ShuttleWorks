# ShuttleWorks scheduler backend — environment template.
#
# Copy to `.env` for local development. The runtime `.env` file is
# gitignored. Production deployments set these via the host's secret
# manager (Fly.io, Render, Supabase) instead of shipping a file.
#
# Every value here is also a code default in ``app/config.py``; this
# file is the canonical list of knobs, not a required configuration.

# ---- Database --------------------------------------------------------
# SQLite for single-laptop / desktop use; Postgres URL for cloud.
# SQLAlchemy auto-selects the driver from the URL scheme.
DATABASE_URL=sqlite:///./local.db
# Postgres example (uncomment for the docker-compose.dev.yml path):
# DATABASE_URL=postgresql://scheduler:scheduler@localhost:5432/scheduler

# ---- Supabase (Step 4 — leave blank for local-only runs) -------------
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ---- Deployment metadata --------------------------------------------
ENVIRONMENT=local
LOG_LEVEL=info

# ---- Network ---------------------------------------------------------
HOST=0.0.0.0
PORT=8000
# Accepts either a JSON list or a comma-separated string.
# Example (JSON):   CORS_ORIGINS=["https://app.example.com"]
# Example (CSV):    CORS_ORIGINS=https://a.example.com,https://b.example.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:3000,http://127.0.0.1:3000,http://localhost:4173,http://127.0.0.1:4173

# ---- Filesystem -----------------------------------------------------
# Writable directory the ``/health/deep`` probe checks. Inside the
# Docker image this is bind-mounted from ./data; outside Docker
# any writable path works. ``BACKEND_DATA_DIR`` is honoured as a
# legacy alias for the same setting.
DATA_DIR=./data
