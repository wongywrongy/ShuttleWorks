{
  "name": "cp-sat-scheduling-engine",
  "private": true,
  "version": "0.0.0",
  "description": "Two-product monorepo: scheduler + tournament + shared design-system.",
  "workspaces": [
    "packages/*",
    "products/scheduler/frontend",
    "products/tournament/frontend"
  ],
  "scripts": {
    "dev:scheduler": "npm run -w products/scheduler/frontend dev",
    "dev:tournament": "npm run -w products/tournament/frontend dev",
    "build:scheduler": "npm run -w products/scheduler/frontend build",
    "build:tournament": "npm run -w products/tournament/frontend build",
    "build:all": "npm run build:scheduler && npm run build:tournament",
    "lint:scheduler": "npm run -w products/scheduler/frontend lint"
  }
}
