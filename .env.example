# ShuttleWorks — repo-root environment template.
#
# This file is committed; the real `.env` (and `.env.local`) files are
# gitignored. Per-service templates with full per-variable docs live at:
#
#   products/scheduler/backend/.env.example
#   products/scheduler/frontend/.env.example
#
# This root file is a single-page reference of every variable the cloud
# deployment needs. Substitute the bracketed placeholders with values
# from your Supabase Dashboard and your deployment hosts. **Never
# commit real values to this repo** — see the secret-hygiene audit
# entry in `docs/changes/` for the guardrails enforcing that.

# ===== Backend (products/scheduler/backend) =========================

# SQLAlchemy URL. SQLite for local dev; Supabase Postgres for cloud.
# Cloud form (use the Supavisor pooler, transaction mode, port 6543):
#   postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=sqlite:///./local.db

# Supabase project URL. Leave blank for local-dev auth bypass.
# Cloud form: https://[PROJECT_ID].supabase.co
SUPABASE_URL=

# Supabase publishable (anon) key. Safe to ship to the browser.
# Cloud form: sb_publishable_[YOUR_KEY]
SUPABASE_ANON_KEY=

# Deployment metadata. ENVIRONMENT=cloud makes the backend require
# the three vars above at startup — empty values raise on boot.
ENVIRONMENT=local
LOG_LEVEL=info

# Network + CORS. JSON-list or CSV both work.
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Writable runtime data directory (health-deep probe checks this).
DATA_DIR=./data

# ===== Frontend (products/scheduler/frontend) =======================

# Backend API base. Vite proxies /api/* in dev; cloud uses the
# absolute deployed backend URL.
#   Cloud form: https://[YOUR-BACKEND-DOMAIN]
VITE_API_BASE_URL=/api

# Supabase URL + publishable key — same values as the backend.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
