# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
.env
*.egg-info/
dist/
build/
*.whl

# IDE
.vscode/
.idea/
*.swp
*.swo
.cursor/
.claude/
.serena/

# Testing
.pytest_cache/
.benchmarks/
.coverage
htmlcov/

# Docker
.docker/

# Documentation
# Block scratch markdown at the repo ROOT only (e.g., prompt dumps, snapshot
# pastes from manual MCP runs). Subdirectory README.md / *.md files are
# tracked normally so feature-folder docs stay in version control.
/*.md
!/README.md

# Old app folders (legacy)
apps/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Frontend (per-product)
**/frontend/node_modules/
**/frontend/dist/
**/frontend/build/
**/frontend/.vite/
**/frontend/.env.local
**/frontend/.env.*.local

# Persisted state (Docker volumes; runtime, not source)
**/data/

# E2E tests (per-product)
**/e2e/node_modules/
**/e2e/playwright-report/
**/e2e/test-results/
**/e2e/blob-report/
**/e2e/.playwright/

# Playwright MCP scratch dir — screenshots, page snapshots, console logs,
# and any downloaded artifacts from browser_navigate / browser_take_screenshot.
.playwright-mcp/

# Loose debug artifacts dropped at the repo root during manual MCP testing.
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webm
/schedule_*.csv
/schedule_*.xlsx
/roster_*.csv
/roster_*.xlsx
/matches_*.csv
/matches_*.xlsx

# UI-iteration screenshots — kept locally as visual references but not
# version-controlled; they age out quickly with frontend changes.
**/docs/screenshots/
