# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
*.whl

# Environment files — never committed.
# `.env.example` (committed templates) is whitelisted below so new
# contributors see what variables each service expects. Anything
# matching the patterns above it is ignored at any directory depth.
.env
.env.local
.env.*.local
*.env
!.env.example
!**/.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo
.cursor/
.claude/
.serena/
# codanna code-intelligence MCP server. The index lives OUTSIDE the repo
# (~/.codanna), and .codanna/settings.toml holds machine-specific absolute paths
# + a project-id, so the whole dir is per-developer. Portable bits are committed:
# .mcp.json (server registration) and .codannaignore. The trailing slash ignores
# only the DIRECTORY — the .codannaignore file stays tracked.
.codanna/
# Claude Code skill plugins installed locally. Skills already committed
# (design-taste-frontend, full-output-enforcement, high-end-visual-design,
# redesign-existing-projects) stay tracked — gitignore only applies to
# untracked paths, so locking the directory doesn't un-stage anything.
.agents/

# Testing
.pytest_cache/
.ruff_cache/
.benchmarks/
.coverage
htmlcov/
coverage/

# Docker
.docker/

# Documentation
# Block scratch markdown at the repo ROOT only (e.g., prompt dumps, snapshot
# pastes from manual MCP runs). Subdirectory README.md / *.md files are
# tracked normally so feature-folder docs stay in version control.
/*.md
!/README.md
!/CLAUDE.md
!/REFACTOR_PROGRESS.md

# Old app folders (legacy)
apps/

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Frontend (per-product + root workspace)
/node_modules/
**/frontend/node_modules/
**/frontend/dist/
**/frontend/build/
**/frontend/tsconfig.tsbuildinfo
packages/*/node_modules/
packages/*/dist/
**/frontend/.vite/

# Persisted state (Docker volumes; runtime, not source)
**/data/

# Local SQLite databases (dev + tests)
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# E2E tests (per-product)
**/e2e/node_modules/
**/e2e/playwright-report/
**/e2e/test-results/
**/e2e/blob-report/
**/e2e/.playwright/
**/e2e/shots/

# Playwright MCP scratch dir — screenshots, page snapshots, console logs,
# and any downloaded artifacts from browser_navigate / browser_take_screenshot.
.playwright-mcp/

# Loose debug artifacts dropped at the repo root during manual MCP testing.
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webm
/schedule_*.csv
/schedule_*.xlsx
/roster_*.csv
/roster_*.xlsx
/matches_*.csv
/matches_*.xlsx

# UI-iteration screenshots — kept locally as visual references but not
# version-controlled; they age out quickly with frontend changes.
**/docs/screenshots/

# Playwright baseline screenshot output — regenerated by the e2e
# `99-baseline-screenshots.spec.ts` run on every CI build, so the
# PNGs themselves don't belong in version control. Already in the
# root .dockerignore; mirror it here.
design/baseline/

# Superpowers SDD scratch (ledger, briefs, reports, review packages, brainstorm artifacts)
.superpowers/

# VitePress docs site — build output + dependency cache (regenerated by docs:build).
# Un-anchored so a stray root .vitepress/cache (from running vitepress without the
# docs arg) is ignored too.
.vitepress/dist/
.vitepress/cache/
docs/.vitepress/dist/
docs/.vitepress/cache/
