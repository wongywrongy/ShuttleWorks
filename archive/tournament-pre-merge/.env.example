# Copy to `.env` to override defaults. Compose auto-loads this file.
#
# Project name is what `docker compose -p <name> ...` shows; it
# namespaces containers, networks, and volumes. Keep this distinct
# from any other prototype on the same Docker daemon.
COMPOSE_PROJECT_NAME=tournament

# Host ports. These differ from BTP (80 / 8000) on purpose so both
# stacks can run side-by-side without touching each other.
FRONTEND_HOST_PORT=5174
BACKEND_HOST_PORT=8765
